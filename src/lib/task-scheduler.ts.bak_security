// @ts-nocheck
/**
 * Task Scheduler - Agent任务调度引擎
 * 支持并行子智能体执行、超时控制、失败重试、状态持久化
 */
import { ToolLoopAgent, isStepCount, tool, readUIMessageStream, toUIMessageStream } from 'ai';
import { z } from 'zod';
import { query, queryOne, run, getSetting } from '@/lib/db';
import { logger } from './logger';

// ============ 任务状态 ============
export type TaskStatus = 'pending' | 'running' | 'completed' | 'failed' | 'timeout' | 'cancelled';

export interface TaskDefinition {
  id: string;
  agent_type: string;
  description: string;
  context?: string;
  timeout_ms?: number;
  max_retries?: number;
  priority?: number; // 1-5, higher = more important
}

export interface TaskResult {
  id: string;
  status: TaskStatus;
  result?: string;
  error?: string;
  duration_ms: number;
  tool_calls_count: number;
  retries: number;
}

// ============ 子智能体配置（升级版） ============
// 子智能体配置类型定义（所有真实配置从DB读取，这里仅定义类型和最小fallback）
export interface SubAgentConfig {
  instructions: string;
  toolNames: string[];
  description: string;
  defaultTimeout: number;
  temperature?: number;
  preferredModel?: string;
  maxSteps?: number;
}

// 最小fallback：DB无数据时使用，确保系统可用
export const SUBAGENT_CONFIGS: Record<string, SubAgentConfig> = {
  researcher: { description: '研究助手', defaultTimeout: 120000, instructions: '你是一个研究助手。', toolNames: ['searchWeb', 'readFile', 'runCommand'] },
  coder: { description: '编程助手', defaultTimeout: 180000, instructions: '你是一个编程助手。', toolNames: ['createFile', 'editFile', 'readFile', 'runCommand', 'ssh_read_file', 'ssh_write_file', 'ssh_execute', 'build_project', 'deploy_service'] },
  reviewer: { description: '代码审查', defaultTimeout: 90000, instructions: '你是一个代码审查专家。', toolNames: ['readFile', 'runCommand', 'ssh_read_file'] },
  writer: { description: '文案写作', defaultTimeout: 60000, instructions: '你是一个文案写作助手。', toolNames: ['searchWeb', 'createFile', 'readFile'] },
  tester: { description: '测试验证', defaultTimeout: 120000, instructions: '你是一个测试验证专家。', toolNames: ['readFile', 'runCommand', 'build_project', 'deploy_service', 'health_check'] },
  planner: { description: '任务规划', defaultTimeout: 60000, instructions: '你是一个任务规划专家。', toolNames: ['readFile', 'searchWeb', 'ssh_read_file'] },
  deployer: { description: '专职部署', defaultTimeout: 180000, instructions: '你是一个部署工程师。', toolNames: ['ssh_read_file', 'ssh_write_file', 'ssh_execute', 'runCommand', 'build_project', 'deploy_service', 'health_check'] },
  analyst: { description: '数据分析', defaultTimeout: 90000, instructions: '你是一个数据分析专家。', toolNames: ['readFile', 'runCommand', 'ssh_read_file', 'searchWeb'] },
  debugger: { description: 'Bug排查', defaultTimeout: 120000, instructions: '你是一个Bug排查专家。', toolNames: ['readFile', 'runCommand', 'ssh_read_file', 'ssh_write_file', 'build_project', 'deploy_service', 'health_check'] },
};


// ============ DB配置加载（覆盖硬编码默认值） ============
async function getSubAgentConfig(agentType: string): Promise<SubAgentConfig | null> {
  // 优先从DB读取完整配置，硬编码仅作为DB无数据时的最小fallback
  try {
    const dbConfig = await getSetting('sub_agent_configs');
    if (dbConfig) {
      const dbParsed = JSON.parse(dbConfig);
      const dbAgent = dbParsed[agentType];
      if (dbAgent) {
        const fallback = SUBAGENT_CONFIGS[agentType];
        return {
          description: dbAgent.description || fallback?.description || '',
          defaultTimeout: (dbAgent.defaultTimeout || (fallback?.defaultTimeout || 120000) / 1000) * 1000,
          instructions: dbAgent.instructions || fallback?.instructions || '',
          toolNames: dbAgent.toolNames || fallback?.toolNames || [],
          temperature: dbAgent.temperature ?? fallback?.temperature,
          preferredModel: dbAgent.preferredModel || fallback?.preferredModel,
          maxSteps: dbAgent.maxSteps ?? fallback?.maxSteps,
        };
      }
    }
  } catch {}
  // DB无数据时返回硬编码fallback
  return SUBAGENT_CONFIGS[agentType] || null;
}

// ============ 任务持久化 ============
async function persistTask(task: TaskDefinition, status: TaskStatus, result?: string, error?: string) {
  try {
    const existing = await queryOne('SELECT id FROM agent_tasks WHERE id = $1', [task.id]);
    if (existing) {
      await run(
        `UPDATE agent_tasks SET status=$1, result=$2, error=$3, updated_at=NOW()${status === 'running' ? ', started_at=NOW()' : ''}${status === 'completed' || status === 'failed' || status === 'timeout' ? ', completed_at=NOW()' : ''} WHERE id=$4`,
        [status, result || null, error || null, task.id]
      );
    } else {
      await run(
        `INSERT INTO agent_tasks (id, task_type, agent_type, description, status, created_at, updated_at, metadata) VALUES ($1,$2,$3,$4,$5,NOW(),NOW(),$6)`,
        [task.id, 'sub_agent', task.agent_type, task.description, status, JSON.stringify({ context: task.context, priority: task.priority })]
      );
    }
  } catch (e) {
    logger.warn(`[TaskScheduler] Failed to persist task ${task.id}: ${e.message}`);
  }
}


// ============ 共享上下文管理（子智能体间传递结果） ============
let currentSessionId: string | null = null;

export function setSchedulerSessionId(sessionId: string) {
  currentSessionId = sessionId;
}

export async function writeSharedContext(sourceTaskId: string, sourceAgentType: string, key: string, value: string) {
  try {
    const sid = currentSessionId || 'default';
    await run(
      `INSERT INTO agent_shared_context (session_id, source_task_id, source_agent_type, key, value) VALUES ($1, $2, $3, $4, $5)`,
      [sid, sourceTaskId, sourceAgentType, key, value.slice(0, 50000)]
    );
  } catch (e) {
    logger.warn(`[TaskScheduler] Failed to write shared context: ${e.message}`);
  }
}

export async function readSharedContext(sourceAgentType?: string, key?: string, limit: number = 10): Promise<string> {
  try {
    const sid = currentSessionId || 'default';
    let sql = `SELECT source_agent_type, key, LEFT(value, 2000) as value, created_at FROM agent_shared_context WHERE session_id = $1`;
    const params: any[] = [sid];
    if (sourceAgentType) { sql += ` AND source_agent_type = $${params.length + 1}`; params.push(sourceAgentType); }
    if (key) { sql += ` AND key = $${params.length + 1}`; params.push(key); }
    sql += ` ORDER BY created_at DESC LIMIT $${params.length + 1}`;
    params.push(limit);
    const rows = await query(sql, params);
    if (!rows || rows.length === 0) return '(无共享上下文)';
    return rows.map((r: any) => `[${r.source_agent_type}] ${r.key || '结果'}: ${r.value}`).join('\n');
  } catch (e) {
    return `(读取共享上下文失败: ${e.message})`;
  }
}

export async function clearSharedContext() {
  try {
    const sid = currentSessionId || 'default';
    await run(`DELETE FROM agent_shared_context WHERE session_id = $1`, [sid]);
  } catch (e) {
    logger.warn(`[TaskScheduler] Failed to clear shared context: ${e.message}`);
  }
}

// ============ 单任务执行器 ============
async function executeSingleTask(
  task: TaskDefinition,
  model: any,
  baseTools: Record<string, any>,
  abortSignal?: AbortSignal
): Promise<TaskResult> {
  const startTime = Date.now();
  const config = await getSubAgentConfig(task.agent_type);
  if (!config) {
    return { id: task.id, status: 'failed', error: `未知子智能体类型: ${task.agent_type}`, duration_ms: 0, tool_calls_count: 0, retries: 0 };
  }

  const timeoutMs = task.timeout_ms || config.defaultTimeout;
  const maxRetries = task.max_retries ?? 1;
  let lastError: string | undefined;
  let attempts = 0;

  for (let attempt = 0; attempt <= maxRetries; attempt++) {
    attempts = attempt;
    if (abortSignal?.aborted) {
      return { id: task.id, status: 'cancelled', duration_ms: Date.now() - startTime, tool_calls_count: 0, retries: attempt };
    }

    try {
      await persistTask(task, 'running');

      // Build sub-agent tools
      const subTools: Record<string, any> = {};
      for (const name of config.toolNames) {
        if (baseTools[name]) subTools[name] = baseTools[name];
      }

      if (Object.keys(subTools).length === 0) {
        return { id: task.id, status: 'failed', error: `无可用工具（需要: ${config.toolNames.join(', ')}）`, duration_ms: Date.now() - startTime, tool_calls_count: 0, retries: attempt };
      }

      // P78: 子智能体ToolLoopAgent加P76/P77保护——不再裸创建
      const subAgentMaxSteps = config.maxSteps || 10;
      const subagent = new ToolLoopAgent({
        model,
        instructions: config.instructions,
        tools: subTools,
        stopWhen: isStepCount(subAgentMaxSteps),
        prepareStep: async ({ messages, stepNumber }: any) => {
          // P76保护: 子智能体内部消息也标准化
          for (const msg of messages) {
            if (msg.role === "tool" && typeof msg.content === "string") {
              try {
                const parsed = JSON.parse(msg.content);
                if (Array.isArray(parsed)) { (msg as any).content = parsed; }
              } catch {
                const tcid = (msg as any).toolCallId || "";
                const tname = (msg as any).toolName || "unknown";
                (msg as any).content = [{ type: "tool-result", toolCallId: tcid, toolName: tname, output: { type: "text", value: msg.content } }];
              }
            }
            // 截断过长工具输出
            if (msg.role === "tool" && Array.isArray(msg.content)) {
              for (const part of msg.content) {
                if (part.type === "tool-result" && part.output?.type === "text" && part.output.value.length > 6000) {
                  part.output.value = part.output.value.substring(0, 6000) + "\n...[子智能体输出截断]";
                }
              }
            }
          }
          return { messages };
        },
      });

      const prompt = task.context ? `${task.description}\n\n上下文：${task.context}` : task.description;

      // P78: 子智能体stream加try-catch + 模型降级重试
      const MAX_SUBAGENT_RETRIES = 1;
      let subRetryCount = 0;
      let resultPromise: any;
      while (subRetryCount <= MAX_SUBAGENT_RETRIES) {
        try {
          resultPromise = subagent.stream({ prompt, abortSignal });
          // 验证stream可启动（await第一步）
          break;
        } catch (streamErr: any) {
          const errMsg = String(streamErr?.message || streamErr || "").toLowerCase();
          logger.warn("[TaskScheduler] Sub-agent stream error (attempt " + (subRetryCount+1) + "): " + errMsg);
          if (errMsg.includes("zod") || errMsg.includes("validation") || subRetryCount >= MAX_SUBAGENT_RETRIES) {
            throw streamErr;
          }
          subRetryCount++;
        }
      }
      const timeoutPromise = new Promise<never>((_, reject) =>
        setTimeout(() => reject(new Error(`Task timeout after ${timeoutMs}ms`)), timeoutMs)
      );

      const result = await Promise.race([resultPromise, timeoutPromise]);

      // Collect output
      let fullText = '';
      let toolCallsCount = 0;

      for await (const message of readUIMessageStream({
        stream: toUIMessageStream({ stream: result.stream }),
      })) {
        const textParts = (message?.parts || []).filter((p: any) => p.type === 'text');
        const currentText = textParts.map((p: any) => p.text || '').join('');
        if (currentText) fullText = currentText;

        const toolParts = (message?.parts || []).filter((p: any) =>
          p.type?.startsWith('tool-') || p.type === 'dynamic-tool'
        );
        toolCallsCount += toolParts.length;
      }

      // P78: fallback - try result.text directly if readUIMessageStream missed it
      if (!fullText) { try { fullText = await result.text || ''; } catch {} }
      const taskResult = fullText || '(子智能体执行完成，无文本输出)';
      await persistTask(task, 'completed', taskResult);

      // 写入共享上下文，供后续子智能体读取
      await writeSharedContext(task.id, task.agent_type, `result_${task.id}`, taskResult);
      
      // Check for follow-up messages from parent (bidirectional communication)
      try {
        const pendingMsgs = await getPendingSubAgentMessages(currentSessionId || 'default', task.id);
        if (pendingMsgs.length > 0) {
          logger.info(`[TaskScheduler] Sub-agent ${task.id} has ${pendingMsgs.length} follow-up messages`);
          const followUpPrompt = pendingMsgs.join('\n');
          const followUpResult = await subagent.stream({ 
            prompt: `Follow-up from parent: ${followUpPrompt}\n\nPlease address the above.`, 
            abortSignal 
          });
          let followUpText = '';
          for await (const message of readUIMessageStream({
            stream: toUIMessageStream({ stream: followUpResult.stream }),
          })) {
            const textParts = (message?.parts || []).filter((p: any) => p.type === 'text');
            const currentText = textParts.map((p: any) => p.text || '').join('');
            if (currentText) followUpText = currentText;
          }
          if (followUpText) {
            await sendFromSubAgent(currentSessionId || 'default', task.id, followUpText);
            return {
              id: task.id, status: 'completed',
              result: taskResult + '\n\n[Follow-up response]: ' + followUpText,
              duration_ms: Date.now() - startTime, tool_calls_count: toolCallsCount, retries: attempt,
            };
          }
        }
      } catch (e: any) {
        logger.warn(`[TaskScheduler] Follow-up message processing failed: ${e.message}`);
      }

      return {
        id: task.id,
        status: 'completed',
        result: taskResult,
        duration_ms: Date.now() - startTime,
        tool_calls_count: toolCallsCount,
        retries: attempt,
      };

    } catch (e: any) {
      lastError = e.message || '未知错误';
      if (e.name === 'AbortError') {
        await persistTask(task, 'cancelled', undefined, '用户取消');
        return { id: task.id, status: 'cancelled', duration_ms: Date.now() - startTime, tool_calls_count: 0, retries: attempt };
      }
      if (attempt < maxRetries) {
        logger.info(`[TaskScheduler] Task ${task.id} attempt ${attempt + 1} failed, retrying...`);
        await new Promise(r => setTimeout(r, 2000)); // Wait 2s before retry
      }
    }
  }

  await persistTask(task, 'failed', undefined, lastError);
  return { id: task.id, status: 'failed', error: lastError, duration_ms: Date.now() - startTime, tool_calls_count: 0, retries: attempts };
}

// ============ 并行任务调度器 ============
export async function executeParallel(
  tasks: TaskDefinition[],
  model: any,
  baseTools: Record<string, any>,
  options: {
    abortSignal?: AbortSignal;
    maxConcurrency?: number;
    onProgress?: (completed: number, total: number, taskId: string, status: TaskStatus) => void;
  } = {}
): Promise<TaskResult[]> {
  const { abortSignal, maxConcurrency = 3, onProgress } = options;
  const total = tasks.length;
  let completed = 0;
  const results: TaskResult[] = [];

  // Persist all tasks as pending
  for (const task of tasks) {
    await persistTask(task, 'pending');
  }

  // Execute with concurrency limit
  const executing: Promise<void>[] = [];

  for (const task of tasks) {
    if (abortSignal?.aborted) break;

    const promise = executeSingleTask(task, model, baseTools, abortSignal).then(result => {
      results.push(result);
      completed++;
      onProgress?.(completed, total, task.id, result.status);
    });

    executing.push(promise);

    // Concurrency control
    if (executing.length >= maxConcurrency) {
      await Promise.race(executing);
      // Remove completed promises
      for (let i = executing.length - 1; i >= 0; i--) {
        // Check if promise is settled by racing with an already-resolved promise
        const settled = await Promise.race([
          executing[i].then(() => true, () => true),
          Promise.resolve(false)
        ]);
        // Can't reliably check, just wait for all when at limit
      }
    }
  }

  // Wait for remaining tasks
  await Promise.allSettled(executing);

  return results;
}

// ============ 顺序任务调度器 ============
export async function executeSequential(
  tasks: TaskDefinition[],
  model: any,
  baseTools: Record<string, any>,
  options: {
    abortSignal?: AbortSignal;
    onProgress?: (completed: number, total: number, taskId: string, status: TaskStatus) => void;
  } = {}
): Promise<TaskResult[]> {
  const { abortSignal, onProgress } = options;
  const results: TaskResult[] = [];

  for (const task of tasks) {
    if (abortSignal?.aborted) break;
    const result = await executeSingleTask(task, model, baseTools, abortSignal);
    results.push(result);
    onProgress?.(results.length, tasks.length, task.id, result.status);
  }

  return results;
}

// ============ 创建 plan_and_execute 工具 ============
export function createPlanAndExecuteTool(model: any, baseTools: Record<string, any>) {
  return tool({
    description: `规划并执行多步骤任务。当你遇到复杂需求时使用此工具，它会：
1. 自动将任务拆解为多个子任务
2. 按依赖关系决定并行或顺序执行
3. 支持researcher/coder/reviewer/writer/tester/planner六种子智能体
4. 每个子任务有独立超时和重试机制
5. 汇总所有子任务结果

适用场景：多文件修改、研究+编码+测试组合、大型功能开发、代码审查+修复等`,
    inputSchema: z.object({
      tasks: z.array(z.object({
        id: z.string().describe('任务短标识，如 research_1, code_2'),
        agent_type: z.enum(['researcher', 'coder', 'reviewer', 'writer', 'tester', 'planner']).describe('子智能体类型'),
        description: z.string().describe('任务描述，要具体明确'),
        context: z.string().optional().describe('额外上下文或依赖信息'),
        timeout_seconds: z.number().optional().describe('超时秒数，默认使用智能体默认值'),
        max_retries: z.number().optional().describe('最大重试次数，默认1'),
      })).describe('子任务列表'),
      strategy: z.enum(['parallel', 'sequential', 'auto']).describe('执行策略：parallel=并行执行（独立任务），sequential=顺序执行（有依赖），auto=自动判断'),
      max_concurrency: z.number().optional().describe('并行时最大并发数，默认3'),
    }),
    execute: async function ({ tasks, strategy, max_concurrency }, { abortSignal }) {
      const taskDefs: TaskDefinition[] = tasks.map(t => ({
        id: t.id,
        agent_type: t.agent_type,
        description: t.description,
        context: t.context,
        timeout_ms: t.timeout_seconds ? t.timeout_seconds * 1000 : undefined,
        max_retries: t.max_retries,
      }));

      // Determine execution strategy
      const hasDependencies = strategy === 'sequential' || 
        (strategy === 'auto' && tasks.some(t => t.context && t.context.length > 20));

      const progressLog: string[] = [];

      const options = {
        abortSignal,
        maxConcurrency: max_concurrency || 3,
        onProgress: (completed: number, total: number, taskId: string, status: TaskStatus) => {
          progressLog.push(`[${completed}/${total}] ${taskId}: ${status}`);
          logger.info(`[TaskScheduler] Progress: ${completed}/${total} - ${taskId} ${status}`);
        },
      };

      try {
        let results: TaskResult[];

        // Sequential mode: auto-pass previous results to next task
        if (hasDependencies) {
          const previousResults: string[] = [];
          results = [];
          for (let i = 0; i < taskDefs.length; i++) {
            const prevContext = previousResults.length > 0 
              ? `\n\n【前序任务结果】\n${previousResults.join('\n---\n')}` 
              : '';
            const enhancedTask = { ...taskDefs[i], context: (taskDefs[i].context || '') + prevContext };
            const result = await executeSingleTask(enhancedTask, model, baseTools, abortSignal);
            results.push(result);
            if (result.status === 'completed' && result.result) {
              previousResults.push(`[${taskDefs[i].agent_type}] ${taskDefs[i].description}: ${result.result.slice(0, 2000)}`);
            }
            options.onProgress?.(results.length, taskDefs.length, taskDefs[i].id, result.status);
          }
        } else {
          results = await executeParallel(taskDefs, model, baseTools, options);
        }

        // Format aggregated results
        const completed = results.filter(r => r.status === 'completed');
        const failed = results.filter(r => r.status !== 'completed');
        const totalDuration = results.reduce((sum, r) => sum + r.duration_ms, 0);

        let output = `📊 任务执行完成\n`;
        output += `总计: ${results.length}个任务 | 成功: ${completed.length} | 失败: ${completed.length < results.length ? results.length - completed.length : 0}`;
        output += ` | 总耗时: ${(totalDuration / 1000).toFixed(1)}s\n\n`;

        for (const r of results) {
          const icon = r.status === 'completed' ? '✅' : r.status === 'failed' ? '❌' : '⏹️';
          output += `${icon} [${r.id}] (${r.agent_type || 'unknown'}) ${r.status}`;
          if (r.duration_ms) output += ` - ${(r.duration_ms / 1000).toFixed(1)}s`;
          if (r.retries > 0) output += ` (重试${r.retries}次)`;
          output += '\n';
          if (r.result) {
            const truncated = r.result.length > 1500 ? r.result.slice(0, 1500) + '\n...(已截断)' : r.result;
            output += truncated + '\n';
          }
          if (r.error) output += `错误: ${r.error}\n`;
          output += '\n';
        }

        return output;

      } catch (e: any) {
        return `任务调度执行失败: ${e.message || '未知错误'}`;
      }
    },
  });
}

// ============ 创建 delegate_task 工具（兼容旧版，升级为新架构） ============
export function createSubAgentTool(model: any, baseTools: Record<string, any>) {
  return tool({
    description: '委派单个任务给子智能体。可用类型：researcher（研究搜索）、coder（编码实现）、reviewer（代码审查）、writer（文案写作）、tester（测试验证）、planner（任务规划）。适合单步任务。多步复杂任务请用 plan_and_execute。',
    inputSchema: z.object({
      agent_type: z.enum(['researcher', 'coder', 'reviewer', 'writer', 'tester', 'planner']).describe('子智能体类型'),
      task: z.string().describe('要委派的任务描述'),
      context: z.string().optional().describe('额外上下文信息'),
    }),
    execute: async function ({ agent_type, task, context }, { abortSignal }) {
      const taskId = `${agent_type}_${Date.now().toString(36)}`;
      const taskDef: TaskDefinition = {
        id: taskId,
        agent_type,
        description: task,
        context,
      };

      const result = await executeSingleTask(taskDef, model, baseTools, abortSignal);

      if (result.status === 'completed') {
        return `[子智能体 ${agent_type} 已完成] 耗时${(result.duration_ms / 1000).toFixed(1)}s\n\n${result.result}`;
      }
      return `子智能体 ${agent_type} 执行${result.status}: ${result.error || '未知错误'}`;
    },
  });
}

// 兼容旧版导出
export const subAgentTools = {};




// ============ Sub-agent Bidirectional Messaging ============
// Allows parent agent to send follow-up messages to sub-agents

export async function sendToSubAgent(sessionId: string, taskId: string, content: string): Promise<void> {
  try {
    await run(
      `INSERT INTO sub_agent_messages (session_id, task_id, direction, content) VALUES ($1, $2, 'to_sub', $3)`,
      [sessionId, taskId, content.slice(0, 50000)]
    );
  } catch (e: any) {
    logger.warn(`[TaskScheduler] Failed to send message to sub-agent: ${e.message}`);
  }
}

export async function getPendingSubAgentMessages(sessionId: string, taskId: string): Promise<string[]> {
  try {
    const rows = await query(
      `SELECT id, content FROM sub_agent_messages 
       WHERE session_id = $1 AND task_id = $2 AND direction = 'to_sub' AND is_read = FALSE 
       ORDER BY created_at ASC`,
      [sessionId, taskId]
    );
    if (!rows || rows.length === 0) return [];
    const ids = rows.map((r: any) => r.id);
    await run(
      `UPDATE sub_agent_messages SET is_read = TRUE WHERE id = ANY($1)`,
      [ids]
    );
    return rows.map((r: any) => r.content);
  } catch (e: any) {
    logger.warn(`[TaskScheduler] Failed to get pending messages: ${e.message}`);
    return [];
  }
}

export async function sendFromSubAgent(sessionId: string, taskId: string, content: string): Promise<void> {
  try {
    await run(
      `INSERT INTO sub_agent_messages (session_id, task_id, direction, content) VALUES ($1, $2, 'from_sub', $3)`,
      [sessionId, taskId, content.slice(0, 50000)]
    );
  } catch (e: any) {
    logger.warn(`[TaskScheduler] Failed to send message from sub-agent: ${e.message}`);
  }
}

export async function getSubAgentResponses(sessionId: string, taskId: string): Promise<string[]> {
  try {
    const rows = await query(
      `SELECT id, content FROM sub_agent_messages 
       WHERE session_id = $1 AND task_id = $2 AND direction = 'from_sub' AND is_read = FALSE 
       ORDER BY created_at ASC`,
      [sessionId, taskId]
    );
    if (!rows || rows.length === 0) return [];
    const ids = rows.map((r: any) => r.id);
    await run(
      `UPDATE sub_agent_messages SET is_read = TRUE WHERE id = ANY($1)`,
      [ids]
    );
    return rows.map((r: any) => r.content);
  } catch (e: any) {
    return [];
  }
}

// ============ 创建 aggregate_results 工具（汇总子智能体结果） ============
export function createAggregateResultsTool() {
  return tool({
    description: '汇总所有子智能体的执行结果，提取关键信息生成综合报告。当你用 plan_and_execute 执行多个子任务后，用此工具汇总结果。',
    inputSchema: z.object({
      focus: z.string().optional().describe('汇总关注点，如"代码修改"、"研究发现"等'),
      format: z.enum(['summary', 'detailed', 'action_items']).optional().describe('输出格式：summary=简要总结，detailed=详细报告，action_items=行动项列表'),
    }),
    execute: async function ({ focus, format: fmt = 'summary' }) {
      const sharedData = await readSharedContext(undefined, undefined, 50);
      if (sharedData === '(无共享上下文)') {
        return '当前没有子智能体的执行结果可以汇总。请先使用 plan_and_execute 或 delegate_task 执行任务。';
      }
      const focusText = focus ? `\n重点关注：${focus}` : '';
      let output = `📋 子智能体执行结果汇总${focusText}\n\n${sharedData}`;
      if (fmt === 'action_items') {
        output += '\n\n⚡ 建议后续行动：\n- 根据以上结果确定下一步操作\n- 如有失败任务，分析原因并重新规划';
      } else if (fmt === 'detailed') {
        output += '\n\n📝 详细模式：以上为所有子智能体的完整输出，请根据需要进一步分析。';
      }
      return output;
    },
  });
}

// ============ 创建 reflect_and_improve 工具（Agent自我反思） ============
export function createReflectTool(model: any) {
  return tool({
    description: `Agent自我反思工具。在完成复杂任务后调用，评估结果质量并发现改进点。

使用场景：
- 完成代码修改后，反思是否遗漏了边界情况
- 执行部署后，反思是否有更优方案
- 完成多步骤任务后，总结经验教训
- 检测到错误时，反思根因是否已真正修复

反思后会自动将洞察保存为记忆，供未来参考。`,
    parameters: z.object({
      task_description: z.string().describe('刚才完成的任务描述'),
      result_summary: z.string().describe('任务结果的简要总结'),
      quality_score: z.number().min(1).max(5).describe('结果质量自评：1=很差 2=差 3=一般 4=好 5=优秀'),
      issues_found: z.string().optional().describe('发现的问题或遗漏'),
      lessons_learned: z.string().optional().describe('经验教训，将被保存为长期记忆'),
      next_steps: z.string().optional().describe('建议的后续行动'),
    }),
    execute: async function ({ task_description, result_summary, quality_score, issues_found, lessons_learned, next_steps }) {
      // 保存反思结果到记忆
      try {
        const { run } = await import('@/lib/db');
        const memId = 'reflect_' + Date.now();
        const content = `反思[${quality_score}/5]: ${task_description} → ${result_summary}${issues_found ? ' | 问题: ' + issues_found : ''}${lessons_learned ? ' | 教训: ' + lessons_learned : ''}`;
        await run(
          `INSERT INTO user_memory (id, category, content, importance, memory_tier, "createdAt", "updatedAt", last_accessed_at) VALUES ($1,'reflection',$2,$3,'long_term',NOW(),NOW(),NOW())`,
          [memId, content, Math.min(quality_score, 4)]
        );
      } catch (e: any) {
        console.error('[Reflect] Failed to save reflection:', e?.message);
      }

      // 生成反思报告
      let report = `🪞 自我反思报告\n`;
      report += `━━━━━━━━━━━━━━━━━━━━\n`;
      report += `📋 任务: ${task_description}\n`;
      report += `⭐ 质量评分: ${'★'.repeat(quality_score)}${'☆'.repeat(5 - quality_score)} (${quality_score}/5)\n`;
      report += `📝 结果: ${result_summary}\n`;
      if (issues_found) report += `⚠️ 问题: ${issues_found}\n`;
      if (lessons_learned) report += `💡 经验: ${lessons_learned}\n`;
      if (next_steps) report += `➡️ 后续: ${next_steps}\n`;
      
      if (quality_score <= 2) {
        report += `\n🔴 质量不达标，建议：重新审视方案或补充步骤`;
      } else if (quality_score === 3) {
        report += `\n🟡 质量一般，可改进`;
      } else {
        report += `\n🟢 质量良好`;
      }
      
      return report;
    },
  });
}

// ============ 创建 memory_maintenance 工具（记忆维护） ============
export function createMemoryMaintenanceTool() {
  return tool({
    description: '记忆维护工具。清理过期短期记忆、降级长期未访问的中期记忆。建议每天自动调用一次。',
    parameters: z.object({
      action: z.enum(['cleanup_expired', 'demote_mid_term', 'stats', 'full_maintenance']).describe('操作类型'),
    }),
    execute: async function ({ action }) {
      const { run, query } = await import('@/lib/db');
      const results: string[] = [];
      
      if (action === 'cleanup_expired' || action === 'full_maintenance') {
        const r = await run('DELETE FROM user_memory WHERE expires_at IS NOT NULL AND expires_at < NOW()');
        results.push(`清理过期短期记忆: ${r?.rowCount || 0}条`);
      }
      
      if (action === 'demote_mid_term' || action === 'full_maintenance') {
        const r = await run("UPDATE user_memory SET memory_tier = 'long_term', expires_at = NULL WHERE memory_tier = 'mid_term' AND last_accessed_at < NOW() - INTERVAL '7 days'");
        results.push(`降级中期记忆: ${r?.rowCount || 0}条`);
      }
      
      if (action === 'stats' || action === 'full_maintenance') {
        const stats = await query(`
          SELECT memory_tier, COUNT(*) as count, 
                 COUNT(*) FILTER(WHERE embedding IS NOT NULL) as with_embedding
          FROM user_memory 
          WHERE expires_at IS NULL OR expires_at > NOW()
          GROUP BY memory_tier ORDER BY memory_tier
        `);
        results.push('记忆统计: ' + stats.map((s: any) => `${s.memory_tier || '未分类'}: ${s.count}条(含embedding:${s.with_embedding})`).join(', '));
      }
      
      return '🔧 记忆维护完成\n' + results.join('\n');
    },
  });
}
